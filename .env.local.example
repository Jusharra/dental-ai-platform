# ============================================================================
# DENTAL AI PLATFORM - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# WEBHOOK SECURITY (REQUIRED)
# ============================================================================
# Generate a secret: openssl rand -hex 32
# 1. Set it here (used by the webhook route to verify incoming requests)
# 2. Run in Supabase SQL Editor:
#    UPDATE practices SET webhook_secret = 'your-value-here';
# 3. Add x-webhook-secret: <value> header in every Make.com HTTP module

WEBHOOK_SECRET=your-random-secret-for-webhook-verification

# ============================================================================
# APPLICATION URL (REQUIRED)
# ============================================================================
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app  (set this in Vercel env vars too)
# Used by Settings page to display Make.com webhook endpoint URLs

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# STRIPE (REQUIRED for billing)
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY          → Secret key (sk_live_... or sk_test_...)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY → Publishable key (pk_live_... or pk_test_...)
# STRIPE_WEBHOOK_SECRET      → Stripe Dashboard → Webhooks → endpoint → Signing secret
#                              Local dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# STRIPE_PRICE_STARTER       → Price ID for Serenity Capture ($295/mo)
# STRIPE_PRICE_PROFESSIONAL  → Price ID for Serenity Complete ($495/mo)
# STRIPE_PRICE_ENTERPRISE    → Price ID for Enterprise (custom)

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_PROFESSIONAL=price_your-professional-price-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-price-id

# ============================================================================
# MAKE.COM INTEGRATION (OPTIONAL)
# ============================================================================
# Only needed if calling Make.com API directly from the app.
# The 3 webhook endpoints (inbound/recall/confirmation) do NOT need these —
# Make.com calls us; we don't call Make.com.

MAKE_API_KEY=your-make-api-key
MAKE_ORGANIZATION_ID=your-org-id
MAKE_TEAM_ID=your-team-id

# ============================================================================
# RETELL AI (OPTIONAL)
# ============================================================================
# Only needed if calling Retell AI API directly

RETELL_API_KEY=your-retell-api-key

# ============================================================================
# CRON SECURITY
# ============================================================================
# Generate: openssl rand -hex 32
# Set same value in Vercel → Settings → Cron Job Secret (or pass as Authorization header)

CRON_SECRET=your-random-cron-secret

# ============================================================================
# EMAIL / SMS (OPTIONAL - Future features)
# ============================================================================

# Resend (for transactional emails — used by Insurance Verification forms)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# VAPI (AI Voice Widget - Marketing Site)
# ============================================================================
# Get these from: https://dashboard.vapi.ai
# NEXT_PUBLIC_VAPI_PUBLIC_KEY  → Your VAPI public key (safe to expose in browser)
# NEXT_PUBLIC_VAPI_ASSISTANT_ID → The assistant ID for the marketing chat widget

NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Node environment
NODE_ENV=development

# ============================================================================
# FEATURE FLAGS (OPTIONAL)
# ============================================================================

ENABLE_SMS_REMINDERS=false
ENABLE_EMAIL_MARKETING=false
ENABLE_PMS_INTEGRATIONS=false
